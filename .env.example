DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_database_user
DB_PASS=your_database_password
DB_NAME=your_database_name

BOT_API_BASE_URL=https://your-newapi-domain.com
BOT_API_ACCESS_TOKEN=sk-your-bot-admin-token
BOT_API_ADMIN_USER_ID=1

